# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env

# API base URL (futuro backend)
VITE_API_URL=https://api.iforms.com.br

# Chave pública de analytics (ex: PostHog, Mixpanel)
VITE_ANALYTICS_KEY=

# ID do projeto para notificações push (VAPID)
VITE_VAPID_PUBLIC_KEY=

# Ambiente
VITE_ENV=development
